{
    "version": 2,
    "builds": [
        { "src": "index.html", "use": "@vercel/static" },
        { "src": "scaling-kit.html", "use": "@vercel/static" },
        { "src": "thank-you.html", "use": "@vercel/static" },
        { "src": "sops/**/*.html", "use": "@vercel/static" },
        { "src": "blog/**/*.html", "use": "@vercel/static" },
        { "src": "tools/**/*.html", "use": "@vercel/static" },
        { "src": "sitemap.xml", "use": "@vercel/static" },
        { "src": "robots.txt", "use": "@vercel/static" },
        { "src": "api/**/*.js", "use": "@vercel/node" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/$1.js", "methods": ["GET", "POST", "OPTIONS"] },
        { "src": "/sitemap\\.xml$", "dest": "/sitemap.xml" },
        { "src": "/robots\\.txt$", "dest": "/robots.txt" },
        { "src": "/thank-you$", "dest": "/thank-you.html" },
        { "src": "/scaling-kit$", "dest": "/scaling-kit.html" },
        { "src": "/blog/states/([^/]+)$", "dest": "/blog/states/$1.html" },
        { "src": "/blog/states/?$", "dest": "/blog/states/index.html" },
        { "src": "/blog/([^/]+)$", "dest": "/blog/$1.html" },
        { "src": "/blog/?$", "dest": "/blog/index.html" },
        { "src": "/tools/([^/]+)$", "dest": "/tools/$1.html" },
        { "src": "/tools/?$", "dest": "/tools/cost-per-door.html" },
        { "src": "/sops/([^/]+)\\.html$", "dest": "/sops/$1.html" },
        { "src": "/sops/?$", "dest": "/sops/index.html" },
        { "src": "^/$", "dest": "/index.html" }
    ]
}
